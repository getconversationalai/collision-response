# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
# ---------------------------------------------------------------------------

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated auth.users.id list — these users can access /admin
ADMIN_USER_IDS=uuid-1,uuid-2

# --- Stripe billing (migration 004) ---
# Use sk_test_... / whsec_... values in development.
STRIPE_SECRET_KEY=sk_live_xxx
# Signing secret of the webhook endpoint configured in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# The single shared Product the operator creates in the Stripe dashboard.
# Per-client Prices are created automatically by the app.
STRIPE_PRODUCT_ID=prod_xxx

# Base URL used to build Stripe Checkout / Customer Portal redirect URLs.
# No trailing slash.
NEXT_PUBLIC_APP_URL=https://collisionping.com

# Optional — only needed if a future change uses Stripe.js on the client.
# The current build uses hosted Stripe Checkout + Customer Portal (redirects
# only), so no code reads this today.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
